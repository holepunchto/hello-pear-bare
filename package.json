{
  "name": "hello-pear-cli",
  "version": "0.4.0",
  "description": "Pear Runtime CLI boilerplate using Bare with OTA updater support.",
  "private": true,
  "main": "index.js",
  "upgrade": "pear://4qxy4f4fdmg1pw3w96cm8sj6h4u9xmbn5hwpm8kg3acnwbr47rdy",
  "scripts": {
    "format": "prettier . --write",
    "test": "brittle-bare test/index.js",
    "lint": "prettier . --check && lunte",
    "start": "bare index.js --no-updates",
    "build:darwin-arm64": "bare-build --config ./bare-build.config.cjs --host darwin-arm64 --out ./out/darwin-arm64 index.js",
    "build:darwin-x64": "bare-build --config ./bare-build.config.cjs --host darwin-x64 --out ./out/darwin-x64 index.js",
    "build:linux-arm64": "bare-build --config ./bare-build.config.cjs --host linux-arm64 --out ./out/linux-arm64 index.js",
    "build:linux-x64": "bare-build --config ./bare-build.config.cjs --host linux-x64 --out ./out/linus-x64 index.js",
    "build:win32-x64": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Build-Win32X64.ps1",
    "build:win32-x64:msix": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Build-Win32X64.ps1 -Msix"
  },
  "dependencies": {
    "bare-os": "^3.9.0",
    "bare-path": "^3.0.0",
    "bare-storage": "^1.1.0",
    "corestore": "^7.9.2",
    "hyperswarm": "^4.17.0",
    "paparam": "^1.10.1",
    "pear-runtime": "^1.1.1",
    "which-runtime": "^1.3.2"
  },
  "devDependencies": {
    "bare-build": "^0.5.3",
    "brittle": "^3.19.0",
    "lunte": "^1.2.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/holepunchto/hello-pear-cli.git"
  },
  "author": "Holepunch Inc",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/hello-pear-cli/issues"
  }
}
